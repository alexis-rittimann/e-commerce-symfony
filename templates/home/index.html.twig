{% extends 'base.html.twig' %}

{% block title %}OLEA — Huiles pressées à froid, en France{% endblock %}

{% block body %}
<main class="p-home">

    {# ===================== Hero ===================== #}
    <section class="hero">
        <div class="hero-l">
            <div class="kick mono">Atelier d'huiles · France</div>
            <h1 class="hbig">Pressées<br>à <em>froid.</em><br>Point.</h1>
            <div class="bottom">
                <p>Olive, colza, noix — extraites à moins de 27°C, sans solvant. Le goût brut de la graine, rien d'ajouté.</p>
                <a class="cta" href="#shop">Voir la boutique →</a>
            </div>
        </div>
        <div class="hero-r">
            <img src="{{ asset('images/products/huile-olive.webp') }}" alt="Huile d'olive OLEA sur lit d'olives" class="hero-img">
            <div class="ticket"><b>28€/L</b><span>Vierge extra</span></div>
        </div>
    </section>

    {# ===================== Ticker ===================== #}
    <div class="ticker"><span>Vierge extra ✦ Sans solvant ✦ Première pression ✦ Origine France ✦ Récolte 2025 ✦ Vierge extra ✦ Sans solvant ✦ Première pression ✦</span></div>

    {# ===================== Boutique (produits depuis la base) ===================== #}
    <section class="sec" id="shop">
        <div class="sechead">
            <h2>La boutique</h2>
            <span class="idx mono">[ {{ products|length }} références ]</span>
        </div>
        <div class="grid">
            {% for product in products %}
                <a class="card" href="{{ path('app_product_show', {id: product.id}) }}">
                    <div class="imgw">
                        <span class="num">{{ '%02d'|format(loop.index) }}</span>
                        {% if loop.first %}<span class="badge">Best-seller</span>{% endif %}
                        {% if product.picture %}
                            <img src="{{ asset('images/products/' ~ product.picture) }}" alt="{{ product.name }}" loading="lazy">
                        {% else %}
                            <div class="ph" data-label="{{ product.name }}"></div>
                        {% endif %}
                    </div>
                    <div class="info">
                        <h3>{{ product.name }}</h3>
                        <span class="desc">{{ product.shortDescription }}</span>
                        <div class="row">
                            <span class="price">{{ product.price|number_format(2, ',', ' ') }} €</span>
                            <span class="plus">+</span>
                        </div>
                    </div>
                </a>
            {% else %}
                <p>Aucun produit pour le moment.</p>
            {% endfor %}
        </div>
    </section>

    {# ===================== Bandeau stats ===================== #}
    <section class="band">
        <div class="bandin">
            <h2>Une seule <em>pression.</em> À froid. Sans compromis.</h2>
            <div class="stat"><b>&lt;27°</b><span>Température max d'extraction. Zéro chauffe, arômes intacts.</span></div>
            <div class="stat"><b>0</b><span>Solvant, additif, conservateur. Que de l'huile, vraiment.</span></div>
        </div>
    </section>

    {# ===================== Le procédé ===================== #}
    <section class="sec">
        <div class="proc">
            <div class="media"><div class="ph dark" data-label="Photo atelier — pressoir, filets d'huile"></div></div>
            <div class="txt">
                <div class="kick mono">Le procédé</div>
                <h2>Du champ à la bouteille en 24h</h2>
                <p>On récolte à maturité, on presse mécaniquement le jour même, on met en verre teinté. C'est tout — et c'est ce qui change tout.</p>
                <div class="steps">
                    <div class="s"><b>01</b><p>Récolte à la main, pressée sous 24h.</p></div>
                    <div class="s"><b>02</b><p>Pression mécanique à froid, sous 27°C.</p></div>
                    <div class="s"><b>03</b><p>Mise en bouteille teintée, à l'abri de la lumière.</p></div>
                </div>
            </div>
        </div>
    </section>

</main>
{% endblock %}
