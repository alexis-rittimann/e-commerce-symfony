{% extends 'base.html.twig' %}

{% block title %}Mon compte — GreenGoodies{% endblock %}

{% block body %}
<main class="p-account">
    <div class="account-wrap">
        <h1>Mon compte</h1>

        {# --- Historique des commandes --- #}
        <section class="acc-block">
            <h2>Mes commandes</h2>
            {% if orders is empty %}
                <p class="muted">Vous n'avez pas encore passé de commande.</p>
            {% else %}
                <div class="orders">
                    <div class="order-head">
                        <span>N°</span>
                        <span>Date</span>
                        <span>Prix</span>
                    </div>
                    {% for order in orders %}
                        <div class="order-row">
                            <span>{{ order.number }}</span>
                            <span>{{ order.validatedAt|date('d/m/Y') }}</span>
                            <span>{{ order.total|number_format(2, ',', ' ') }}€</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        {# --- Accès API --- #}
        <section class="acc-block">
            <h2>Mon accès API</h2>
            <form method="post" action="{{ path('app_account_api_toggle') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle-api') }}">
                <button type="submit" class="account-btn">
                    {{ app.user.apiAccessEnabled ? 'Désactiver mon accès API' : 'Activer mon accès API' }}
                </button>
            </form>
        </section>

        {# --- Suppression du compte --- #}
        <section class="acc-block">
            <form method="post" action="{{ path('app_account_delete') }}" onsubmit="return confirm('Supprimer définitivement votre compte ? Cette action est irréversible.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-account') }}">
                <button type="submit" class="account-btn">Supprimer mon compte</button>
            </form>
        </section>
    </div>
</main>
{% endblock %}
