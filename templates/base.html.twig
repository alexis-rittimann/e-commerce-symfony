<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}GreenGoodies — Produits durables et éthiques{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌿</text></svg>">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {# ===================== Header / navigation (toutes pages) ===================== #}
        <header>
            <nav class="nav">
                <div class="left">
                    <a class="brand" href="{{ path('app_home') }}">
                        <span class="logo-mark">G</span>
                        <span class="logo-text">Green Goodies</span>
                    </a>
                </div>
                <div class="right">
                    {% if app.user %}
                        <a class="lnk" href="{{ path('app_home') }}">Nos produits</a>
                        <a class="lnk" href="{{ path('app_cart') }}">Mon panier</a>
                        <a class="lnk" href="{{ path('app_account') }}">Mon compte</a>
                        <a class="lnk" href="{{ path('app_logout') }}">Déconnexion</a>
                    {% else %}
                        <a class="lnk" href="{{ path('app_login') }}">Connexion</a>
                        <a class="lnk" href="{{ path('app_register') }}">Inscription</a>
                    {% endif %}
                </div>
            </nav>
        </header>

        {# Messages flash (confirmation de commande, panier vidé, etc.) #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}

        {# ===================== Footer (présent sur toutes les pages) ===================== #}
        <footer class="site-footer">© GreenGoodies - {{ "now"|date("Y") }}</footer>
    </body>
</html>
