{% extends 'base.html.twig' %}

{% block title %}Mon panier — OLEA{% endblock %}

{% block body %}
<main class="p-cart">
    <div class="cart-wrap">
        <h1>Mon panier</h1>

        {% if cart.items is empty %}
            <p class="empty">Votre panier est vide. <a href="{{ path('app_home') }}">Voir la boutique →</a></p>
        {% else %}
            <div class="cart-table">
                <div class="cart-head">
                    <span>Produit</span>
                    <span>Quantité</span>
                    <span>Prix unitaire</span>
                    <span>Total</span>
                </div>
                {% for item in cart.items %}
                    <div class="cart-line">
                        <div class="cl-product">
                            <div class="cl-img">
                                {% if item.product.picture %}
                                    <img src="{{ asset('images/products/' ~ item.product.picture) }}" alt="{{ item.product.name }}">
                                {% else %}
                                    <div class="ph" data-label="{{ item.product.name }}"></div>
                                {% endif %}
                            </div>
                            <div class="cl-name">
                                <a href="{{ path('app_product_show', {id: item.product.id}) }}">{{ item.product.name }}</a>
                                <span>{{ item.product.shortDescription }}</span>
                            </div>
                        </div>
                        <div class="cl-qty"><span class="lbl">Quantité</span>{{ item.quantity }}</div>
                        <div class="cl-unit"><span class="lbl">Prix unitaire</span>{{ item.unitPrice|number_format(2, ',', ' ') }} €</div>
                        <div class="cl-total"><span class="lbl">Total</span>{{ item.lineTotal|number_format(2, ',', ' ') }} €</div>
                    </div>
                {% endfor %}
            </div>

            <div class="cart-foot">
                <div class="cart-total">Total commande <b>{{ cart.total|number_format(2, ',', ' ') }} €</b></div>
                <div class="cart-actions">
                    <form method="post" action="{{ path('app_cart_clear') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('clear-cart') }}">
                        <button type="submit" class="btn-ghost">Vider le panier</button>
                    </form>
                    <form method="post" action="{{ path('app_cart_validate') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('validate-order') }}">
                        <button type="submit" class="cta">Valider la commande →</button>
                    </form>
                </div>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}
