{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} — GreenGoodies{% endblock %}

{% block body %}
<main class="p-product">
    <section class="product">
        {# --- Image produit (gauche) --- #}
        <div class="gallery">
            {% if product.picture %}
                <img src="{{ asset('images/products/' ~ product.picture) }}" alt="{{ product.name }}">
            {% else %}
                <div class="ph" data-label="{{ product.name }}"></div>
            {% endif %}
        </div>

        {# --- Panneau d'achat (droite) --- #}
        <div class="panel">
            <div>
                <h1 class="p-title">{{ product.name }}</h1>
                <p class="price">{{ product.price|number_format(2, ',', ' ') }} €</p>
                <div class="p-desc">{{ product.fullDescription }}</div>
            </div>

            <div class="buy">
                {% if app.user %}
                    <form method="post" action="{{ path('app_cart_add', {id: product.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('add-to-cart') }}">
                        <div class="qty-row">
                            <span class="qty-label">Quantité</span>
                            <div class="qty" data-controller="quantity">
                                <button type="button" data-action="quantity#decrease">–</button>
                                <input type="number" name="quantity" min="0" value="{{ cartQuantity > 0 ? cartQuantity : 1 }}" data-quantity-target="input">
                                <button type="button" data-action="quantity#increase">+</button>
                            </div>
                        </div>
                        <button type="submit" class="add">
                            {{ cartQuantity > 0 ? 'Mettre à jour' : 'Ajouter au panier' }}
                        </button>
                    </form>
                {% else %}
                    <a class="cta login-cta" href="{{ path('app_login') }}">Se connecter pour commander</a>
                {% endif %}
            </div>
        </div>
    </section>
</main>
{% endblock %}
