{% extends 'base.html.twig' %}

{% block title %}Inscription — GreenGoodies{% endblock %}

{% block body %}
<main class="p-auth">
    <div class="auth-image"><img src="{{ asset('images/branch-mimosa.webp') }}" alt="Branche fleurie"></div>

    <div class="auth-form">
        <h1>Inscription</h1>
        <p class="required-note">Tous les champs sont obligatoires.</p>

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.firstName) }}
            {{ form_row(registrationForm.lastName) }}
            {{ form_row(registrationForm.email) }}
            {{ form_row(registrationForm.plainPassword.first) }}
            {{ form_row(registrationForm.plainPassword.second) }}

            <div class="cgu-row">
                {{ form_widget(registrationForm.agreeTerms) }}
                {{ form_label(registrationForm.agreeTerms) }}
            </div>
            {{ form_errors(registrationForm.agreeTerms) }}

            <button type="submit" class="auth-submit">Créer mon compte</button>
        {{ form_end(registrationForm) }}

        <p class="switch"><a href="{{ path('app_login') }}">Déjà un compte ? Se connecter</a></p>
    </div>
</main>
{% endblock %}
